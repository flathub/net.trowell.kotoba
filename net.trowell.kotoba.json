{
    "id" : "net.trowell.kotoba",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "sdk-extensions" : [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command" : "kotoba",
    "finish-args" : [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin"
    },
    "modules" : [
        {
            "name": "kotoba",
            "builddir": true,
            "buildsystem": "meson",
            "config-opts": [
                "--buildtype=release"
            ],
            "sources": [
                "generated-sources.json",
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/haydn/kotoba.git",
                    "tag": "0.2.1",
                    "commit": "0a320d1257ba22c0e41afefcedf955297e63a50d"
                },
                {
                    "type": "inline",
                    "contents": "[source.crates-io]\nreplace-with = \"vendored-sources\"\n\n[source.vendored-sources]\ndirectory = \"cargo/vendor\"\n",
                    "dest": ".cargo",
                    "dest-filename": "config.toml"
                }
            ]
        }
    ]
}